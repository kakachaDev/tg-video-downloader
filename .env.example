# Token from @BotFather
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat ID where the bot temporarily uploads files to get a Telegram file_id.
# Easiest option: your own Telegram user ID (get it from @userinfobot).
# Start the bot once (/start) so it can write to your chat.
STORAGE_CHAT_ID=123456789

# Your Telegram user ID — only this account can run /cookie.
ADMIN_USER_ID=123456789

# (Optional) Path where the bot saves cookies.txt uploaded via /cookie.
# Defaults to cookies.txt in the working directory.
# COOKIES_FILE=cookies.txt
